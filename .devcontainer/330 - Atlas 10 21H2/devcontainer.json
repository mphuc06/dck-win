{
  "name": "Atlas10 21H2",
  "service": "windows",
  "containerEnv": {
    "VERSION":"https://archive.org/download/atlasosv1803andv20h2andv21h2/Atlas_v0.5.2_21H2.iso"
  },
  "forwardPorts": [8006],
  "portsAttributes": {
    "8006": {
      "label": "Web",
      "onAutoForward": "notify"
    }
  },
  "otherPortsAttributes": {
    "onAutoForward": "ignore"
  }, 
  "dockerComposeFile": "../codespaces.yml",
  "initializeCommand": "docker system prune --all --force"
}
