{
  "name": "Automic 11 by Windows X Lite",
  "service": "windows",
  "containerEnv": {
    "VERSION":"https://github.com/kmille36/idx-windows-gui/releases/download/1.0/virtio-win-0.1.271.iso"
  },
  "forwardPorts": [8006],
  "portsAttributes": {
    "8006": {
      "label": "Web",
      "onAutoForward": "notify"
    }
  },
  "otherPortsAttributes": {
    "onAutoForward": "ignore"
  }, 
  "dockerComposeFile": "../codespaces.yml",
  "initializeCommand": "docker system prune --all --force"
}
